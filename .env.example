# ---------------------------------------------------------------------------
# Plivo (shared, both agents)
# ---------------------------------------------------------------------------
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PUBLIC_DOMAIN=your-ngrok-host.ngrok-free.app

# ---------------------------------------------------------------------------
# Google — used by both agents
#   - agent_native.py uses GOOGLE_API_KEY (Gemini API, Flash Live)
#   - agent_cascaded_google.py uses BOTH:
#       GOOGLE_API_KEY for the LLM
#       GOOGLE_APPLICATION_CREDENTIALS (or credentials_path) for Cloud TTS
# ---------------------------------------------------------------------------
GOOGLE_API_KEY=
# Path to a service-account JSON with roles/cloudtts.user on a GCP project
# that has Cloud Text-to-Speech API enabled.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ---------------------------------------------------------------------------
# Deepgram (Agent B only)
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=

# ---------------------------------------------------------------------------
# Test behaviour
# ---------------------------------------------------------------------------
# Language code for agent_native.py greeting + prompt. Default hi.
ASR_LANGUAGE=en

# Default voice for Agent B (Gemini Flash TTS). Any of the 30 prebuilt:
#   Achernar, Achird, Algenib, Algieba, Alnilam, Aoede, Autonoe, Callirhoe,
#   Charon, Despina, Enceladus, Erinome, Fenrir, Gacrux, Iapetus, Kore,
#   Laomedeia, Leda, Orus, Puck, Pulcherrima, Rasalgethi, Sadachbia,
#   Sadaltager, Schedar, Sulafar, Umbriel, Vindemiatrix, Zephyr, Zubenelgenubi
GEMINI_TTS_VOICE=Aoede
